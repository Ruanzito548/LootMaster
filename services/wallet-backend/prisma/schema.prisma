generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CurrencyCode {
  USD
  BRL
  EUR
  GBP
}

enum WalletTransactionType {
  ORDER_PAYOUT
  WITHDRAWAL_REQUEST
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  ADJUSTMENT_CREDIT
  ADJUSTMENT_DEBIT
  HOLD_APPLIED
  HOLD_RELEASED
}

enum WalletTransactionStatus {
  PENDING
  POSTED
  REVERSED
  FAILED
}

enum OrderStatus {
  CREATED
  PAID
  ASSIGNED
  COMPLETED
  CANCELLED
  DISPUTED
}

enum WithdrawalStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  PROCESSING
  PAID
  CANCELLED
}

enum KycStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum AuditActorType {
  SYSTEM
  ADMIN
  USER
  DISCORD_BOT
}

enum FraudCheckStatus {
  CLEAR
  REVIEW
  BLOCKED
}

model User {
  id                 String                @id @default(cuid())
  siteUserId         String?               @unique @map("site_user_id")
  discordId          String                @unique @map("discord_id")
  discordUsername    String                @map("discord_username")
  email              String?               @unique
  walletId           String?               @unique @map("wallet_id")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  wallet             Wallet?
  applications       SupplierApplication[]
  assignedOrders     Order[]               @relation("AssignedSupplierUser")
  transactions       WalletTransaction[]
  withdrawRequests   WithdrawRequest[]
  kycVerifications   KycVerification[]
  authFingerprints   UserAuthFingerprint[]
  linkTokens         DiscordLinkToken[]

  @@map("users")
}

model Wallet {
  id                String              @id @default(cuid())
  userId            String              @unique @map("user_id")
  availableBalance  Decimal             @default(0) @db.Decimal(18, 2) @map("available_balance")
  lockedBalance     Decimal             @default(0) @db.Decimal(18, 2) @map("locked_balance")
  currency          CurrencyCode        @default(USD)
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  user              User                @relation(fields: [userId], references: [id])
  transactions      WalletTransaction[]
  withdrawRequests  WithdrawRequest[]
  holds             BalanceHold[]

  @@map("wallets")
}

model WalletTransaction {
  id                String                  @id @default(cuid())
  walletId          String                  @map("wallet_id")
  userId            String                  @map("user_id")
  orderId           String?                 @map("order_id")
  withdrawRequestId String?                 @map("withdraw_request_id")
  type              WalletTransactionType
  amount            Decimal                 @db.Decimal(18, 2)
  fee               Decimal                 @default(0) @db.Decimal(18, 2)
  currency          CurrencyCode
  status            WalletTransactionStatus
  referenceKey      String                  @unique @map("reference_key")
  metadata          Json?
  createdAt         DateTime                @default(now()) @map("created_at")
  postedAt          DateTime?               @map("posted_at")
  wallet            Wallet                  @relation(fields: [walletId], references: [id])
  user              User                    @relation(fields: [userId], references: [id])
  order             Order?                  @relation(fields: [orderId], references: [id])
  withdrawRequest   WithdrawRequest?        @relation(fields: [withdrawRequestId], references: [id])

  @@index([walletId, createdAt])
  @@index([userId, type, createdAt])
  @@index([orderId])
  @@map("wallet_transactions")
}

model Order {
  id                        String                @id @default(cuid())
  externalOrderId           String                @unique @map("external_order_id")
  customerId                String?               @map("customer_id")
  assignedSupplierDiscordId String?               @map("assigned_supplier_discord_id")
  assignedSupplierUserId    String?               @map("assigned_supplier_user_id")
  totalAmount               Decimal               @db.Decimal(18, 2) @map("total_amount")
  supplierPayout            Decimal               @db.Decimal(18, 2) @map("supplier_payout")
  currency                  CurrencyCode          @default(USD)
  status                    OrderStatus           @default(CREATED)
  metadata                  Json?
  completedAt               DateTime?             @map("completed_at")
  createdAt                 DateTime              @default(now()) @map("created_at")
  updatedAt                 DateTime              @updatedAt @map("updated_at")
  supplierUser              User?                 @relation("AssignedSupplierUser", fields: [assignedSupplierUserId], references: [id])
  applications              SupplierApplication[]
  walletTransactions        WalletTransaction[]

  @@index([assignedSupplierDiscordId])
  @@index([status, createdAt])
  @@map("orders")
}

model SupplierApplication {
  id              String    @id @default(cuid())
  orderId         String    @map("order_id")
  linkedUserId    String?   @map("linked_user_id")
  discordId       String    @map("discord_id")
  discordUsername String    @map("discord_username")
  appliedAt       DateTime  @default(now()) @map("applied_at")
  accepted        Boolean   @default(false)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  order           Order     @relation(fields: [orderId], references: [id])
  linkedUser      User?     @relation(fields: [linkedUserId], references: [id])

  @@unique([orderId, discordId])
  @@index([discordId])
  @@map("supplier_applications")
}

model DiscordLinkToken {
  id               String    @id @default(cuid())
  linkedUserId     String?   @map("linked_user_id")
  discordId        String    @map("discord_id")
  token            String    @unique
  expiresAt        DateTime  @map("expires_at")
  usedAt           DateTime? @map("used_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  linkedUser       User?     @relation(fields: [linkedUserId], references: [id])

  @@index([discordId, expiresAt])
  @@map("discord_link_tokens")
}

model WithdrawRequest {
  id              String            @id @default(cuid())
  walletId        String            @map("wallet_id")
  userId          String            @map("user_id")
  amount          Decimal           @db.Decimal(18, 2)
  fee             Decimal           @default(0) @db.Decimal(18, 2)
  currency        CurrencyCode
  status          WithdrawalStatus  @default(PENDING_REVIEW)
  payoutMethod    String            @map("payout_method")
  payoutReference Json?             @map("payout_reference")
  metadata        Json?
  requestedAt     DateTime          @default(now()) @map("requested_at")
  approvedAt      DateTime?         @map("approved_at")
  rejectedAt      DateTime?         @map("rejected_at")
  paidAt          DateTime?         @map("paid_at")
  wallet          Wallet            @relation(fields: [walletId], references: [id])
  user            User              @relation(fields: [userId], references: [id])
  transactions    WalletTransaction[]

  @@index([userId, status, requestedAt])
  @@map("withdraw_requests")
}

model AuditLog {
  id                String          @id @default(cuid())
  actorType         AuditActorType  @map("actor_type")
  actorId           String?         @map("actor_id")
  action            String
  entityType        String          @map("entity_type")
  entityId          String          @map("entity_id")
  metadata          Json?
  ipAddress         String?         @map("ip_address")
  userAgent         String?         @map("user_agent")
  deviceFingerprint String?         @map("device_fingerprint")
  createdAt         DateTime        @default(now()) @map("created_at")

  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model KycVerification {
  id             String     @id @default(cuid())
  userId         String     @map("user_id")
  status         KycStatus  @default(NOT_REQUIRED)
  provider       String?
  providerRef    String?    @map("provider_ref")
  reviewedBy     String?    @map("reviewed_by")
  reviewedAt     DateTime?  @map("reviewed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  user           User       @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@map("kyc_verifications")
}

model UserAuthFingerprint {
  id                String           @id @default(cuid())
  userId            String           @map("user_id")
  ipAddress         String?          @map("ip_address")
  userAgent         String?          @map("user_agent")
  deviceFingerprint String?          @map("device_fingerprint")
  riskScore         Int              @default(0) @map("risk_score")
  status            FraudCheckStatus @default(CLEAR)
  firstSeenAt       DateTime         @default(now()) @map("first_seen_at")
  lastSeenAt        DateTime         @default(now()) @map("last_seen_at")
  user              User             @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([deviceFingerprint])
  @@map("user_auth_fingerprints")
}

model BalanceHold {
  id          String    @id @default(cuid())
  walletId    String    @map("wallet_id")
  userId      String    @map("user_id")
  reason      String
  amount      Decimal   @db.Decimal(18, 2)
  releaseAt   DateTime? @map("release_at")
  releasedAt  DateTime? @map("released_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  wallet      Wallet    @relation(fields: [walletId], references: [id])

  @@index([walletId, releaseAt])
  @@map("balance_holds")
}